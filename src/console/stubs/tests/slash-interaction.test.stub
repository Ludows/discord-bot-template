import { describe, it, expect, vi, beforeEach } from 'vitest';
import { {{Name}}Interaction } from '../../src/interactions/{{Name}}Interaction';
import { ChatInputCommandInteraction } from 'discord.js';

const mockSlashInteraction = (subcommand?: string, opts: Record<string, string> = {}) => ({
  commandName: '{{name}}',
  user: { tag: 'user#0001' },
  replied: false,
  deferred: false,
  options: {
    getSubcommand: vi.fn().mockReturnValue(subcommand ?? null),
    getString: vi.fn((key: string) => opts[key] ?? null),
    getBoolean: vi.fn().mockReturnValue(false),
  },
  reply: vi.fn().mockResolvedValue({}),
  update: vi.fn().mockResolvedValue({}),
  respond: vi.fn().mockResolvedValue({}),
  showModal: vi.fn().mockResolvedValue({}),
}) as unknown as ChatInputCommandInteraction;

describe('{{Name}}Interaction', () => {
  let interaction: {{Name}}Interaction;

  beforeEach(() => {
    interaction = new {{Name}}Interaction();
    vi.clearAllMocks();
  });

  it('getName() est correct', () => {
    expect(interaction.getName()).toBe('{{name}}');
  });

  it('toSlashCommand() auto-génère le builder', () => {
    const builder = interaction.toSlashCommand();
    expect(builder.name).toBe('{{name}}');
  });

  it('handleSlash() appelle executeSlash par défaut', async () => {
    const spy = vi.spyOn(interaction, 'executeSlash').mockResolvedValue(undefined);
    const slash = mockSlashInteraction();
    await interaction.handleSlash(slash);
    expect(spy).toHaveBeenCalledOnce();
  });

  it('une erreur remonte en ephemeral par défaut', async () => {
    vi.spyOn(interaction, 'executeSlash').mockRejectedValue(new Error('crash test'));
    const slash = mockSlashInteraction();
    await interaction.handleSlash(slash);
    expect(slash.reply).toHaveBeenCalledWith(expect.objectContaining({ ephemeral: true }));
  });

{{subcommandTests}}
});
